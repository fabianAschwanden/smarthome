<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Use Case 14: Zeitsteuerung der Batterie (SCHEDULE + COUNTDOWN, ein Tisch). -->
    <changeSet id="0006-create-battery-schedule" author="smarthome">
        <createTable tableName="battery_schedule">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="type" type="varchar(16)">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="varchar(8)">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="at_time" type="time"/>
            <column name="weekdays" type="varchar(128)"/>
            <column name="fire_at" type="timestamp with time zone"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
